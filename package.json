{
  "name": "appstore",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "scripts": {
    "build": "webpack",
    "watch": "webpack --watch",
    "start": "npm run build && electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "dist": "npm run build && electron-builder",
    "test": "jest"
  },
  "build": {
    "appId": "com.electron.appdownloader",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "css-loader": "^7.1.4",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "fast-check": "^4.6.0",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^30.3.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ]
